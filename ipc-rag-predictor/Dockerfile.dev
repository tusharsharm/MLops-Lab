FROM python:3.11-slim

WORKDIR /app

# Create non-root user
RUN useradd -m -u 1000 appuser

# Install minimal Python dependencies for dev
COPY requirements.dev.txt ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.dev.txt

# Copy app code
COPY app/ ./app/

RUN mkdir -p /app/data /app/mlruns && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
# Run using `main:app` because the host `app` directory is bind-mounted to /app
# which makes `main.py` accessible as the module `main` in the container cwd.
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
